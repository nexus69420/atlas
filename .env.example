# Copy to .env and adjust for local development.
# Docker Compose injects these for the `api` service automatically.

APP_NAME=Atlas API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Host-machine default (API run outside Docker, Postgres in Docker)
DATABASE_URL=postgresql+psycopg://atlas:atlas@localhost:5432/atlas

# Auth — generate a long random string for anything beyond local dev
SECRET_KEY=dev-only-change-me-atlas-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# Browser origins allowed to call the API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local dataset files (V1 — swap for object storage later)
STORAGE_PATH=storage/datasets
ARTIFACT_STORAGE_PATH=storage/artifacts
MAX_UPLOAD_BYTES=52428800
